#!/bin/sh
set -eu

# Load nvm (works with any node version)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

echo "Running Biome and Vitest checks before commit..."

if ! npx lint-staged; then
  echo "Lint-staged failed, aborting commit."
  exit 1
fi

if ! pnpm run lint:check; then
  echo "Lint failed, aborting commit."
  exit 1
fi

nul_list=$(
  git diff --cached --name-only -z --diff-filter=ACMRTUXB \
  | awk -v RS='\0' 'BEGIN{ORS=""} $0 ~ /\.(ts|tsx|js|jsx)$/ {printf "%s\0", $0}'
)

if [ -z "$nul_list" ]; then
  echo "No testable files staged. Skipping Vitest."
  exit 0
fi

echo "Running related Vitest tests on:"
printf '%s' "$nul_list" | tr '\0' '\n' | sed 's/^/   • /'

printf '%s' "$nul_list" \
| xargs -0 npx vitest related --run --passWithNoTests \
|| { echo "Related tests failed, aborting commit."; exit 1; }

echo "All checks passed."
